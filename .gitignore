__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
venv/
env/
.env/
.venv/
ENV/

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject

# Jupyter Notebook
.ipynb_checkpoints/

# Distribution / packaging
*.tar.gz
*.whl

# Byte-compiled / optimized
*.pyc
*.pyo
*.pyd

# OS files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Node.js ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity
package-lock.json

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Streamlit
.streamlit/secrets.toml
